# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# Comma-separated channel IDs to listen to. Leave empty to listen to ALL channels.
ALLOWED_CHANNEL_IDS=

# Optional: group channels to share conversation history.
# Channels in the same SHARE_HISTORY group share one inbox — Cola sees them as a single conversation.
# Channels not in any group each get their own isolated history.
# SHARE_HISTORY_1=123456789,987654321
# SHARE_HISTORY_2=111222333
